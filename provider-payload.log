      "function": {
        "name": "sem_log",
        "description": "Entity-level history for a function/class/method. Use for debugging regressions, tracing how logic evolved, or understanding who changed a specific entity over time.",
        "parameters": {
          "type": "object",
          "required": [
            "entity"
          ],
          "properties": {
            "entity": {
              "type": "string",
              "description": "Entity name to trace through git history."
